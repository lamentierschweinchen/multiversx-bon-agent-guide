# Copy to .env and fill in values for the BON environment.

# Network label only for your own reference.
NETWORK_NAME=bon

# Fill this with the correct delegation manager address for the target network.
# The docs example for staking providers uses:
# erd1qqqqqqqqqqqqqqqpqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqylllslmq6y6
DELEGATION_MANAGER_ADDRESS=erd1qqqqqqqqqqqqqqqpqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqylllslmq6y6

# Human metadata for the staking provider.
# Name must end with BoN for the competition task.
PROVIDER_NAME=YourProviderBoN
PROVIDER_WEBSITE=https://example.com
PROVIDER_GITHUB=your-github-handle

# Contract-level parameters.
# 0 means unlimited cap.
TOTAL_CAP_EGLD=2500
# Fee in hundredths of a percent. Example: 10.00% => 1000
SERVICE_FEE_BPS=1000

# BON task amounts.
CREATE_PROVIDER_EGLD=1250
TOP_UP_EGLD=1250

# Fill this after createNewDelegationContract succeeds.
DELEGATION_CONTRACT_ADDRESS=

# Path to the validator PEM on your machine.
VALIDATOR_KEY_PEM=

# Fill this after extracting from validatorKey.pem.
BLS_PUBLIC_KEY=

# Fill this after signing the delegation contract address with the validator BLS private key.
BLS_SIGNATURE_HEX=
